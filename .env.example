# CellClaw Configuration
# Copy this file to .env and fill in your values
# ⚠️  DO NOT commit .env to git!

# ── Discord ────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── LLM ────────────────────────────────────────────────────
# Default LLM settings (used by all agents if no agent-specific key set)
OMICS_LLM_BASE_URL=https://api.deepseek.com/v1
OMICS_LLM_API_KEY=your_api_key_here
OMICS_LLM_MODEL=deepseek-chat
OMICS_LLM_MAX_TOKENS=4096

# ── Multi-Agent System (v2.0) ─────────────────────────────────
# Set to "true" to enable multi-agent architecture
# - Orchestrator: Coordinates workflow
# - Planner: Task planning and skill detection
# - Coder: Code generation with skill templates
# - Reviewer: Code review and validation
# - Executor: Job execution and monitoring
MULTI_AGENT_ENABLED=true

# ── Agent API Keys (optional, overrides default above) ──────────
# Only set these if you want different API keys per agent
# If not set, all agents use OMICS_LLM_* settings above
# ORCHESTRATOR_API_KEY=
# PLANNER_API_KEY=
# CODER_API_KEY=
# REVIEWER_API_KEY=
# EXECUTOR_API_KEY=

# ── Proxy ──────────────────────────────────────────────────
# Uncomment and set if your machine needs a proxy
# OMICS_LLM_PROXY=http://127.0.0.1:7890

# ── Bot ────────────────────────────────────────────────────
OMICS_BOT_NAME=CellClaw

# ── Data directory ─────────────────────────────────────────
# OMICSCLAW_DATA=./data
