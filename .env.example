# OmicsClaw — .env example
# Copy to .env and fill in your values:
#   cp .env.example .env
# Or run the setup wizard:
#   bash install.sh

# ── Discord ─────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications → Bot → Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# ── LLM ─────────────────────────────────────────────────────
# DeepSeek (recommended): https://platform.deepseek.com
OMICS_LLM_BASE_URL=https://api.deepseek.com/v1
OMICS_LLM_API_KEY=sk-your_api_key_here
OMICS_LLM_MODEL=deepseek-chat
OMICS_LLM_MAX_TOKENS=4096

# OpenAI alternative:
# OMICS_LLM_BASE_URL=https://api.openai.com/v1
# OMICS_LLM_API_KEY=sk-your_openai_key
# OMICS_LLM_MODEL=gpt-4o

# Kimi alternative:
# OMICS_LLM_BASE_URL=https://api.moonshot.cn/v1
# OMICS_LLM_API_KEY=sk-your_kimi_key
# OMICS_LLM_MODEL=moonshot-v1-8k

# ── Proxy ────────────────────────────────────────────────────
# Required if you need a proxy to reach Discord/LLM APIs
# OMICS_LLM_PROXY=http://127.0.0.1:7890

# ── Bot ──────────────────────────────────────────────────────
OMICS_BOT_NAME=OmicsClaw

# ── Data directory ───────────────────────────────────────────
# Where to store session data, user memory, server configs
# Default: ./data
# OMICSCLAW_DATA=./data
